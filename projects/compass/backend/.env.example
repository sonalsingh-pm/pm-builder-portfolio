# Compass backend — required environment variables
# Copy this file to .env and fill in real values. Never commit .env.

# Google Gemini API key — powers all agents
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Pinecone API key — powers the internal knowledge base (RAG) search
# Optional: if missing, Compass skips internal search gracefully
# Get one at https://app.pinecone.io
PINECONE_API_KEY=your-pinecone-api-key-here

# Notion API key — used to sync internal documents into the knowledge base
# Optional: only needed if you populate the RAG index from Notion
NOTION_API_KEY=your-notion-api-key-here
