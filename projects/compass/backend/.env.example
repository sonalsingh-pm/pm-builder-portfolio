# Compass backend — required environment variables
# Copy this file to .env and fill in real values. Never commit .env.

# Google Gemini API key — powers all agents
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Pinecone API key — powers the internal knowledge base (RAG) search
# Optional: if missing, Compass skips internal search gracefully
# Get one at https://app.pinecone.io
PINECONE_API_KEY=your-pinecone-api-key-here

# Notion API key — NOT USED YET. Planned feature: sync internal documents
# (briefs, PRDs, research) from Notion into the Pinecone knowledge base so
# the Internal Search agent can find prior work. Any placeholder value works.
# TODO: build the Notion -> embeddings -> Pinecone sync script.
NOTION_API_KEY=not-used-yet
